{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.allvaps.fr" }],
      "destination": "https://allvaps.fr/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
