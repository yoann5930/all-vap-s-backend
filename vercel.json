{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.allvaps.fr" }],
      "destination": "https://allvaps.fr/",
      "statusCode": 301
    },
    {
      "source": "/:path((?!_next/|favicon\\.ico|robots\\.txt|sitemap\\.xml|manifest\\.webmanifest|.*\\..+$).*)",
      "has": [{ "type": "host", "value": "www.allvaps.fr" }],
      "destination": "https://allvaps.fr/:path",
      "statusCode": 301
    }
  ]
}
